@startuml use-case-diagram-clean
title Distributed LLM Agents – UML Use Case Diagram

left to right direction

skinparam packageStyle rectangle
skinparam defaultFontName Arial
skinparam shadowing false
skinparam usecase {
    BackgroundColor #EAF4FB
    BorderColor     #2471A3
    FontColor       #17202A
    ArrowColor      #2C3E50
}
skinparam actor {
    BackgroundColor #FEF9E7
    BorderColor     #D4AC0D
    FontColor       #17202A
}
skinparam note {
    BackgroundColor #FDFEFE
    BorderColor     #AAB7B8
}

' ============================================================
' ACTORS
' ============================================================

actor "External User /\nSystem" as User
actor "Research Analyst" as Analyst
actor "System Administrator" as Admin
actor "LLM Provider" as LLMProvider

' ============================================================
' SYSTEM BOUNDARY
' ============================================================

rectangle "Distributed LLM Agents System" {

    ' -- User-facing use cases --------------------------------
    usecase "Submit Task" as UC_Submit
    usecase "Monitor Task Status" as UC_Monitor
    usecase "Retrieve Task Result" as UC_Result
    usecase "Authenticate Request" as UC_Auth

    ' -- Optional user customization --------------------------
    usecase "Configure Decomposition Strategy" as UC_ConfigDecomp

    ' -- Internal orchestration -------------------------------
    usecase "Decompose Task into SubTasks" as UC_Decompose
    usecase "Schedule SubTask" as UC_Schedule
    usecase "Dispatch SubTask" as UC_Dispatch
    usecase "Execute SubTask" as UC_Execute
    usecase "Retry Execution" as UC_Retry
    usecase "Call LLM API" as UC_CallLLM
    usecase "Store Prompt / Response Artifacts" as UC_StoreArtifact

    ' -- Evaluation & reliability -----------------------------
    usecase "Evaluate Execution" as UC_Evaluate
    usecase "Detect Hallucinations" as UC_DetectHalluc
    usecase "Read Artifacts from Object Storage" as UC_ReadArtifact
    usecase "Trigger Fault Recovery" as UC_FaultRecovery
    usecase "Monitor Agent Health" as UC_HealthMonitor
    usecase "Track Heartbeats" as UC_Heartbeat
    usecase "Isolate Failing Agent" as UC_Isolate

    ' -- Consensus --------------------------------------------
    usecase "Aggregate Consensus" as UC_Consensus
    usecase "Apply Consensus Strategy" as UC_ApplyStrategy
    usecase "Escalate to Human Review" as UC_HumanReview

    ' -- Administration ---------------------------------------
    usecase "Configure System" as UC_Configure
    usecase "Set Circuit Breaker Thresholds" as UC_CBThreshold
    usecase "Override Consensus Strategy" as UC_OverrideStrategy

    ' -- Research / analytics ---------------------------------
    usecase "Analyze Research Metrics" as UC_Analyze
    usecase "Query Experiment Tracker" as UC_QueryTracker
    usecase "Export Metrics Report" as UC_Export
}

' ============================================================
' ACTOR ASSOCIATIONS
' ============================================================

User    --> UC_Submit
User    --> UC_Monitor
User    --> UC_Result

Analyst --> UC_Analyze

Admin   --> UC_Configure
Admin   --> UC_HealthMonitor

LLMProvider --> UC_CallLLM

' ============================================================
' INCLUDE RELATIONSHIPS
' ============================================================

' Authentication
UC_Submit  .> UC_Auth : <<include>>
UC_Monitor .> UC_Auth : <<include>>
UC_Result  .> UC_Auth : <<include>>

' Submission pipeline
UC_Submit    .> UC_Decompose : <<include>>
UC_Decompose .> UC_Schedule  : <<include>>
UC_Schedule  .> UC_Dispatch  : <<include>>
UC_Dispatch  .> UC_Execute   : <<include>>

' Execution internals
UC_Execute .> UC_CallLLM       : <<include>>
UC_Execute .> UC_StoreArtifact : <<include>>
UC_Execute .> UC_Evaluate      : <<include>>

' Evaluation internals
UC_Evaluate .> UC_ReadArtifact : <<include>>
UC_Evaluate .> UC_DetectHalluc : <<include>>

' Result retrieval depends on consensus
UC_Result    .> UC_Consensus      : <<include>>
UC_Consensus .> UC_ApplyStrategy  : <<include>>

' Health monitoring
UC_HealthMonitor .> UC_Heartbeat : <<include>>

' Admin / analytics
UC_Configure .> UC_CBThreshold : <<include>>
UC_Analyze   .> UC_QueryTracker : <<include>>

' ============================================================
' EXTEND RELATIONSHIPS
' ============================================================

UC_ConfigDecomp     .> UC_Submit        : <<extend>>
UC_Retry            .> UC_Execute       : <<extend>>
UC_FaultRecovery    .> UC_Evaluate      : <<extend>>
UC_HumanReview      .> UC_Consensus     : <<extend>>
UC_Isolate          .> UC_HealthMonitor : <<extend>>
UC_OverrideStrategy .> UC_Configure     : <<extend>>
UC_Export           .> UC_Analyze       : <<extend>>

@enduml