erDiagram
    direction TB

    agents {
        UUID agent_id PK
        TEXT agent_role
        TEXT llm_model
        TEXT llm_provider
        JSONB capabilities
        TEXT status
        TIMESTAMPTZ registered_at
    }

    tasks {
        UUID task_id PK
        TEXT title
        TEXT description
        TEXT complexity_level
        TEXT status
        TEXT submitted_by
        TIMESTAMPTZ created_at
        TIMESTAMPTZ completed_at
    }

    subtasks {
        UUID subtask_id PK
        UUID task_id FK
        TEXT description
        TEXT required_role
        JSONB dependencies
        INTEGER sequence_order
        TEXT status
        TIMESTAMPTZ created_at
    }

    executions {
        UUID execution_id PK
        UUID subtask_id FK
        UUID agent_id FK
        JSONB input_context
        TEXT raw_output
        INTEGER attempt_number
        TEXT status
        TIMESTAMPTZ started_at
        TIMESTAMPTZ completed_at
    }

    agent_messages {
        UUID message_id PK
        UUID sender_agent_id FK
        UUID receiver_agent_id FK
        UUID task_id FK
        TEXT message_type
        JSONB payload
        TIMESTAMPTZ sent_at
        TIMESTAMPTZ delivered_at
    }

    evaluation_results {
        UUID evaluation_id PK
        UUID execution_id FK
        UUID evaluator_agent_id FK
        NUMERIC hallucination_score
        NUMERIC consistency_score
        TEXT evaluation_notes
        TEXT verdict
        TIMESTAMPTZ evaluated_at
    }

    consensus_records {
        UUID consensus_id PK
        UUID task_id FK
        UUID subtask_id FK
        TEXT strategy
        TEXT final_output
        JSONB participating_agent_ids
        NUMERIC confidence_score
        TIMESTAMPTZ resolved_at
    }

    agents ||--o{ executions : "agent_id"
    tasks ||--o{ subtasks : "task_id"
    subtasks ||--o{ executions : "subtask_id"
    executions ||--o{ evaluation_results : "execution_id"
    subtasks ||--o| consensus_records : "subtask_id"
    tasks ||--o{ consensus_records : "task_id"
    agents ||--o{ agent_messages : "sender_agent_id"
    agents ||--o{ agent_messages : "receiver_agent_id"
    tasks ||--o{ agent_messages : "task_id"
    agents ||--o{ evaluation_results : "evaluator_agent_id"
